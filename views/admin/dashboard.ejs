<section class="admin-shell">
  <%- include('../partials/admin-sidebar', { entities }) %>
  <div class="admin-content">
    <div class="admin-header">
      <div>
        <p class="eyebrow">Administration</p>
        <h1>Dashboard</h1>
      </div>
      <a class="btn btn-outline-dark" href="/">Voir le site</a>
    </div>

    <div class="stats-grid">
      <article><strong><%= stats.counts.projects %></strong><span>Projets</span></article>
      <article><strong><%= stats.counts.schools %></strong><span>Ecoles</span></article>
      <article><strong><%= stats.counts.companies %></strong><span>Entreprises</span></article>
      <article><strong><%= stats.counts.jobs %></strong><span>Experiences</span></article>
      <article><strong><%= stats.counts.educations %></strong><span>Formations</span></article>
      <article><strong><%= stats.counts.skills %></strong><span>Competences</span></article>
    </div>

    <section class="admin-panel">
      <h2>Dernieres modifications</h2>
      <div class="admin-table">
        <% stats.latest.forEach((item) => { %>
          <div class="table-row">
            <span><%= item.type %></span>
            <strong><%= item.title %></strong>
            <small><%= formatDate(item.updated_at) %></small>
          </div>
        <% }) %>
      </div>
    </section>
  </div>
</section>
