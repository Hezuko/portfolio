<nav class="navbar navbar-expand-lg portfolio-navbar">
  <div class="container">
    <a class="navbar-brand brand-mark" href="/">
      <img src="/images/came.png" alt="Logo <%= siteProfile.name %>">
      <span><%= siteProfile.name %></span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Ouvrir la navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <%
      const cp = typeof currentPath === "string" ? currentPath : "/";
      const isCurrent = (href) => {
        if (href === "/") return cp === "/";
        if (href === "/jobs") return cp === "/jobs" || cp.indexOf("/experiences") === 0 || cp.indexOf("/jobs/") === 0;
        return cp === href || cp.indexOf(href + "/") === 0;
      };
      const navAttrs = (href) => isCurrent(href) ? ' aria-current="page" class="nav-link active"' : ' class="nav-link"';
    %>
    <div class="collapse navbar-collapse" id="mainNavbar">
      <ul class="navbar-nav ms-auto align-items-lg-center">
        <li class="nav-item"><a<%- navAttrs("/") %> href="/">Accueil</a></li>
        <li class="nav-item"><a<%- navAttrs("/a-propos") %> href="/a-propos">À propos</a></li>
        <li class="nav-item"><a<%- navAttrs("/projets") %> href="/projets">Projets</a></li>
        <li class="nav-item"><a<%- navAttrs("/etudes") %> href="/etudes">Études</a></li>
        <li class="nav-item"><a<%- navAttrs("/jobs") %> href="/jobs">Expériences</a></li>
        <li class="nav-item"><a class="btn btn-sm btn-dark ms-lg-2" href="/contact">Me contacter</a></li>
        <% if (user && user.role === "admin") { %>
          <li class="nav-item"><a class="btn btn-sm btn-outline-dark ms-lg-2" href="/admin">Admin</a></li>
          <li class="nav-item">
            <form action="/desauthentification" method="POST" class="ms-lg-2 mt-2 mt-lg-0">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-sm btn-outline-dark" type="submit">Logout</button>
            </form>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
