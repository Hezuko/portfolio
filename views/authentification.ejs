<div class="focus-scroll-page auth-page">
  <section class="focus-scroll-section">
    <article class="focus-card auth-card">
      <div class="auth-header">
        <p class="eyebrow">Espace privé</p>
        <h1>Authentification</h1>
        <p>Accès réservé à l'administration du portfolio.</p>
      </div>

      <% if (error) { %>
        <p class="alert alert-danger" role="alert"><%= error %></p>
      <% } %>

      <form class="form-surface auth-form" method="POST" action="/authentification">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>Identifiant
          <input type="text" name="pseudo" autocomplete="username" required autofocus>
        </label>
        <label>Code d'accès
          <input type="password" name="password" autocomplete="current-password" required>
        </label>
        <button class="btn btn-dark" type="submit">S'authentifier</button>
      </form>

      <div class="auth-divider"><span>ou</span></div>
      <a href="/authentification/visiteur" class="btn btn-outline auth-visitor">Continuer en tant que visiteur</a>
    </article>
  </section>
</div>
