<section class="content d-flex justify-content-center align-items-center min-vh-90">
    <div class="col-md-6 text-center p-4 shadow rounded bg-light">
        <h1 class="section-h1">🔐 Authentification</h1>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/authentification" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            
            <div class="mb-3 text-start">
                <label for="pseudo" class="form-label">Identifiant</label>
                <input type="text" id="pseudo" name="pseudo" class="form-control" required>
            </div>
        
            <div class="mb-3 text-start">
                <label for="password" class="form-label">Code d'accès</label>
                <input type="password" id="password" name="password" class="form-control" required>
            </div>
        
            <button type="submit" class="btn btn-primary w-100">S'authentifier</button>
        </form>

        <hr class="my-3">
        <p class="text-muted">Ou</p>
        <a href="/authentification/visiteur" class="btn btn-outline-secondary w-100">🔍 Continuer en tant que visiteur</a>
    </div>
</section>
