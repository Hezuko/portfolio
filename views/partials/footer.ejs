<footer class="site-footer">
  <div class="container footer-top">
    <div class="footer-brand">
      <strong><%= siteProfile.name %></strong>
      <p><%= siteProfile.footerText %></p>
    </div>
    <nav class="footer-col" aria-label="Navigation">
      <span class="footer-col__title">Navigation</span>
      <a href="/">Accueil</a>
      <a href="/a-propos">À propos</a>
      <a href="/projets">Projets</a>
      <a href="/etudes">Études</a>
      <a href="/jobs">Expériences</a>
      <a href="/contact">Me contacter</a>
    </nav>
    <nav class="footer-col" aria-label="Me joindre">
      <span class="footer-col__title">Me joindre</span>
      <% if (siteProfile.email) { %><a href="mailto:<%= siteProfile.email %>"><svg class="bi" width="1em" height="1em" fill="currentColor" aria-hidden="true"><use href="#bi-envelope"></use></svg> Email</a><% } %>
      <% if (siteProfile.github) { %><a href="<%= siteProfile.github %>" target="_blank" rel="noreferrer"><svg class="bi" width="1em" height="1em" fill="currentColor" aria-hidden="true"><use href="#bi-github"></use></svg> GitHub</a><% } %>
      <% if (siteProfile.linkedin) { %><a href="<%= siteProfile.linkedin %>" target="_blank" rel="noreferrer"><svg class="bi" width="1em" height="1em" fill="currentColor" aria-hidden="true"><use href="#bi-linkedin"></use></svg> LinkedIn</a><% } %>
      <% if (siteProfile.cv) { %><a href="<%= siteProfile.cv %>" target="_blank" rel="noreferrer"><svg class="bi" width="1em" height="1em" fill="currentColor" aria-hidden="true"><use href="#bi-file-earmark-text"></use></svg> CV</a><% } %>
    </nav>
  </div>
  <div class="container footer-bottom">
    <p>© <%= new Date().getFullYear() %> <%= siteProfile.name %> — caméléon par nature.</p>
    <nav class="footer-legal" aria-label="Liens légaux">
      <a href="/mentions-legales">Mentions légales</a>
      <a href="/confidentialite">Confidentialité</a>
      <a href="/cookies">Cookies</a>
    </nav>
  </div>
</footer>
