<% const domainEntries = Object.entries(groups); %>
<div class="focus-scroll-page technical-focus-page" data-focus-scroll>
  <section class="focus-scroll-section">
    <article class="focus-card technical-intro-card">
      <p class="eyebrow">Domaines techniques</p>
      <h1>Compétences reliées au parcours</h1>
      <p>Une compétence n’est affichée ici que comme point d’entrée vers les projets, expériences et études où elle apparaît réellement.</p>
    </article>
  </section>

  <% domainEntries.forEach(([domain, items], index) => { %>
    <section class="focus-scroll-section">
      <article class="focus-card technical-domain-section">
        <div class="technical-domain-section__header">
          <h2><%= domain %></h2>
          <p><%= items.length %> compétence<%= items.length > 1 ? 's' : '' %> reliée<%= items.length > 1 ? 's' : '' %> au portfolio</p>
        </div>
        <div class="technical-skill-grid">
          <% items.forEach((item) => { %>
            <article class="technical-skill-card">
              <button class="skill-badge" type="button" data-knowledge-type="<%= item.type %>" data-knowledge-id="<%= item.id %>" aria-label="Afficher la fiche de <%= item.name %>">
                <%= item.name %>
                <% if (item.level) { %><small><%= formatLevel(item.level) %></small><% } %>
              </button>
              <% if (item.description) { %><p><%= item.description %></p><% } %>
              <dl class="skill-relations">
                <div>
                  <dt>Projets</dt>
                  <dd><%= (item.projects || []).length %></dd>
                </div>
                <div>
                  <dt>Expériences</dt>
                  <dd><%= (item.experiences || []).length %></dd>
                </div>
                <div>
                  <dt>Études</dt>
                  <dd><%= (item.studies || []).length %></dd>
                </div>
              </dl>
              <div class="relation-preview">
                <% const usedIn = [...(item.projects || []).map((project) => project.name), ...(item.experiences || []).map((experience) => experience.company_name ? `${experience.title} — ${experience.company_name}` : experience.title), ...(item.studies || []).map((study) => study.school_name ? `${study.title} — ${study.school_name}` : study.title)].slice(0, 3); %>
                <% if (usedIn.length) { %>
                  <% usedIn.forEach((label) => { %><span><%= label %></span><% }) %>
                <% } else { %>
                  <span>Relation à compléter dans l’admin</span>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      </article>
    </section>
  <% }) %>
</div>
