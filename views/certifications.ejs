<% if (certifications.length) { %>
  <% for (let i = 0; i < certifications.length; i += 3) { %> 
    <section class="content">

      <% if (typeof user !== "undefined" && user.role === "admin") { %>
        <div class="position-absolute top-0 end-0 p-3 d-flex gap-2">
          <a href="/certifications/ajouter" class="custom-btn add-btn">
              ➕
          </a>
        </div>
      <% } %>

      <div class="col-md-12 text-center">
        <h1 class="section-h1">Mes certifications</h1>
        <div class="horizontal_line"></div>

        <ul class="list-unstyled diplomes-list">
          <% certifications.slice(i, i + 3).forEach(function(certification) { %>  
            <li class="card custom-card mb-3">
              <div class="d-flex align-items-center">
                <img src="<%= certification.image_path ? certification.image_path : '/images/default_certification.png' %>" 
                     alt="Image de la certification" class="diplome-image">
                <div class="diplome-details">
                  <p><strong>Titre :</strong> <%= certification.titre %></p>
                  <p><strong>Etablissement :</strong> <%= certification.delivrepar %></p>
                </div>
                <% if (typeof user !== "undefined" && user.role === "admin") { %>
                  <div class="d-flex gap-2 ms-3">
                    <a href="/certifications/modifier/<%= certification.id %>" class="custom-btn edit-btn">
                        📝
                    </a>
                    <form action="/certifications/supprimer/<%= certification.id %>" method="POST" class="d-inline">
                        <button type="submit" class="custom-btn delete-btn" 
                                onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette certification ?');">
                            ❌
                        </button>
                    </form>
                  </div>
                <% } %>
              </div>
            </li>
          <% }); %>
        </ul>
      </div>
    </section>
  <% } %>
<% } else { %>
  <section class="content">
    <% if (typeof user !== "undefined" && user.role === "admin") { %>
      <div class="position-absolute top-0 end-0 p-3 d-flex gap-2">
        <a href="/certifications/ajouter" class="custom-btn add-btn">
          ➕ 
        </a>
      </div>
    <% } %>
    
    <div class="col-md-12 text-center">
      <h1 class="section-h1">Aucune certification trouvée</h1>
      <img src="https://res.cloudinary.com/portfolio-hezuko/image/upload/v1740308748/nothing-here.webp" 
           class="img-fluid" style="max-width: 80%; height: auto;">
    </div>
  </section>
<% } %>
