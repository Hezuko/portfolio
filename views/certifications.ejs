<% if (certifications.length) { %>
  <% for (let i = 0; i < certifications.length; i += 3) { %> 
    <section class="content">
      <div class="col-md-12 text-center">
        <h1 class="section-h1">Mes certifications</h1>
        <div class="horizontal_line"></div>

        <ul class="list-unstyled diplomes-list">
          <% certifications.slice(i, i + 3).forEach(function(certification) { %>
            <li class="card custom-card mb-3">
              <div class="d-flex align-items-center">
                <img src="/images/AdobePortfolio.png" alt="Image de la certification" class="diplome-image">
                <div class="diplome-details">
                  <p><strong>Titre :</strong> <%= certification.titre %></p>
                  <p><strong>Etablissement :</strong> <%= certification.delivrepar %></p>
                </div>
              </div>
            </li>
          <% }); %>
        </ul>
      </div>
    </section>
  <% } %>
<% } else { %>
  <section class="content">
    <div class="col-md-12 text-center">
      <h1 class="section-h1">Aucune certification trouvée</h1>
      <img src="/gif/giphy.webp" class="img-fluid" style="max-width: 50%; height: auto;">
    </div>
  </section>
<% } %>
