DB_URL=postgres://postgres:postgres@localhost:5432/portfolio
DB_SSL=false
SESSION_SECRET=change-moi-en-local
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
MAIL_USER=
MAIL_PASS=
MAIL_TO=

# Prod : domaine public utilisé pour canonical / OG / JSON-LD / sitemap.
# Sans lui, ces URLs retombent sur l'hôte de la requête (warning au boot en prod).
SITE_URL=https://exemple.fr
# Prod : active les cookies de session "secure" (HTTPS) et le garde-fou SITE_URL.
NODE_ENV=production
