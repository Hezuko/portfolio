# Modèle pour /srv/portfolio/.env (lu automatiquement par docker compose).
# NE PAS committer le .env réel.

# Domaine public complet (canonical / OG / sitemap)
SITE_URL=https://henoc-mukumbi.com

# Mot de passe de la base Postgres dédiée du portfolio (choisis-en un fort)
DB_PASSWORD=change-moi

# Secret de signature des sessions :  openssl rand -hex 32
SESSION_SECRET=change-moi-long-et-aleatoire

# Compte Cloudinary du portfolio (avec le secret) — sinon photo/logos cassés
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@portfolio-hezuko

# Restriction d'accès au back-office (/authentification + /admin) par IP.
# IP autorisées séparées par des virgules. VIDE = aucune restriction.
# Ex : ADMIN_IP_ALLOWLIST=88.123.45.67,90.10.20.30
ADMIN_IP_ALLOWLIST=

# Email de notification de contact.
# En prod OVH le SMTP sortant est bloqué → on envoie via l'API Brevo (HTTPS).
BREVO_API_KEY=        # clé API Brevo (Settings → SMTP & API → API Keys)
MAIL_FROM=            # expéditeur VÉRIFIÉ dans Brevo (ex. contact@henocmukumbi.com)
MAIL_TO=              # où recevoir les notifications (ex. h.mukumbi100@gmail.com)
MAIL_USER=            # utilisé comme expéditeur si MAIL_FROM vide ; SMTP local (dev) seulement
MAIL_PASS=            # mot de passe d'app Gmail — SMTP local (dev) uniquement, inutile en prod
